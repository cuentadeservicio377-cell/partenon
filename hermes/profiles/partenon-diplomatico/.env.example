# Environment variables for partenon-diplomatico

# Path to the Google Workspace service account JSON file
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/google-service-account.json

# OpenRouter API key for the profile default model
OPENROUTER_API_KEY=sk-or-v1-...

# CRM provider configuration (optional; used by sync_contacts)
CRM_PROVIDER=hubspot
CRM_API_KEY=
CRM_API_URL=

# HubSpot-specific credentials
HUBSPOT_ACCESS_TOKEN=

# Salesforce-specific credentials
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=
SALESFORCE_INSTANCE_URL=

# Meeting scheduler defaults
DEFAULT_MEETING_DURATION_MINUTES=30
DEFAULT_MEETING_TIMEZONE=America/Mexico_City

# Diplomat workspace
PARTENON_RELATIONS_FILE=.relations
PARTENON_DATA_DIR=./data
