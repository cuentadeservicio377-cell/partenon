# Partenon Brain — Environment variables
# Copy this file as .env and fill in real values.

# G-Brain MCP (shared memory)
GBRAIN_DATABASE_URL=postgresql://localhost:5432/gbrain

# OpenRouter API key for the default model
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME_IN_ENV

# Environment: development | staging | production
PARTENON_ENV=development
