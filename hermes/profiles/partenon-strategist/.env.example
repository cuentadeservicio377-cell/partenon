# Partenon Strategist — Environment Variables
# Copy this file to .env and fill in your values.

# Google Workspace service account JSON path.
# Download from Google Cloud Console: APIs & Services > Credentials > Service Account.
GOOGLE_SERVICE_ACCOUNT_JSON=config/google-service-account.json

# OpenRouter API key for the default model.
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: override default data directory.
# PARTENON_DATA_DIR=/path/to/partenon_core/data
