# Partenon Collector — Environment variables
# Copy this file as .env and fill in real values.

# Stripe MCP
STRIPE_SECRET_KEY=sk_test_REPLACE_ME_IN_ENV
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME_IN_ENV

# OpenRouter API key for the profile default model
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME_IN_ENV

# Google Workspace MCP (optional, required to send formal reminders)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# G-Brain MCP (shared memory)
GBRAIN_DATABASE_URL=postgresql://localhost:5432/gbrain
