# Partenon Guardian — environment variables
# Copy to .env and fill with real values. Never commit the .env file.

# NVIDIA API key for Nemotron / NIM model access.
NVIDIA_API_KEY=nvapi-...

# OpenAI API key for GPT model access.
OPENAI_API_KEY=sk-...

# Kimi API key for Kimi model access.
KIMI_API_KEY=...

# Stripe secret key for payment management operations.
# The Guardian stores and rotates this key; it does not execute charges.
STRIPE_SECRET_KEY=sk_test_...
