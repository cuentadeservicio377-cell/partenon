{
  "name": "daily-followups",
  "description": "Review pending Diplomat follow-ups every morning.",
  "enabled": true,
  "schedule": {
    "cron": "0 8 * * *",
    "timezone": "America/Mexico_City"
  },
  "profile": "partenon-diplomat",
  "skill": "relations",
  "action": {
    "tool": "followups.py",
    "function": "run_daily_followups",
    "args": {
      "alert_days": [1, 3, 7],
      "channels": ["gmail", "google_workspace"]
    }
  },
  "outputs": [
    {
      "type": "gbrain_mission",
      "description": "Register daily follow-up mission"
    },
    {
      "type": "calendar_event",
      "description": "Create blocking event if there are critical milestones"
    }
  ]
}
