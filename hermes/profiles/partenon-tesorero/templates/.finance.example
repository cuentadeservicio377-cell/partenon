[reglas]
# Reglas de negocio del Tesorero
iva = 0.16
margen_minimo_esperado = 30.0
alerta_dias_vencimiento = 3
redondeo_decimales = 2
permite_gasto_sin_presupuesto = false
conecta_con_mensajero = true
