# Treasurer configuration file
# Copy as .finance in the workspace root of the company

[company]
name = "Hermes Example Inc."
tax_id = "XAXX010101000"
currency = "MXN"
fiscal_year = 2026
responsible = "Treasurer"
master_spreadsheet = ""

[fixed_costs]
# Recurring expenses with predictable amount
[[fixed_costs.item]]
name = "Office rent"
amount = 15000.00
frequency = "monthly"
category = "office"
due_day = 5

[[fixed_costs.item]]
name = "Base salaries"
amount = 45000.00
frequency = "biweekly"
category = "payroll"
due_day = 15

[[fixed_costs.item]]
name = "Cloud services"
amount = 2500.00
frequency = "monthly"
category = "technology"
due_day = 20

[variable_costs]
# Expenses that change according to operation volume
[[variable_costs.item]]
name = "Production materials"
category = "materials"
monthly_budget = 30000.00

[[variable_costs.item]]
name = "Digital advertising"
category = "marketing"
monthly_budget = 12000.00
default_vendor = "Google Ads"

[[variable_costs.item]]
name = "Shipping and freight"
category = "logistics"
monthly_budget = 5000.00

[budgets]
# Active budgets by area
[[budgets.area]]
name = "Operations"
amount = 100000.00
period = "2026-Q3"
responsible = "Strategist"

[[budgets.area]]
name = "Marketing"
amount = 50000.00
period = "2026-Q3"
responsible = "Messenger"

[[budgets.area]]
name = "Technology"
amount = 25000.00
period = "2026-Q3"
responsible = "Guardian"

[vendors]
# Directory of usual vendors
[[vendors.item]]
id = "P001"
name = "Central Stationery"
contact = "Ana Garcia"
phone = "555-0104"
email = "ana@papeleriacentral.com"
payment_terms = "cash"
lead_time = "1-2 business days"
rating = 5

[[vendors.item]]
id = "P002"
name = "Cloud MX Services"
contact = "Carlos Ruiz"
phone = "555-0201"
email = "carlos@cloudmx.com"
payment_terms = "30 days"
lead_time = "immediate"
rating = 4

[dashboards]
# Financial dashboard sheets
[[dashboards.sheet]]
name = "Monthly Summary"
type = "kpi"
update = "daily"

[[dashboards.sheet]]
name = "Cash Flow"
type = "projection"
update = "weekly"

[[dashboards.sheet]]
name = "Vendors"
type = "directory"
update = "monthly"

[[dashboards.sheet]]
name = "Budget vs Actual"
type = "comparative"
update = "weekly"

[rules]
# Treasurer business rules
tax_rate = 0.16
minimum_expected_margin = 30.0
alert_days_before_due = 3
rounding_decimals = 2
allow_expense_without_budget = false
connect_with_messenger = true
