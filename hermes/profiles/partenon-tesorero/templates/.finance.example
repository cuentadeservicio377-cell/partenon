# Archivo de configuracion del Tesorero
# Copiar como .finance en la raiz del workspace de la empresa

[empresa]
nombre = "Hermes Ejemplo S.A. de C.V."
rfc = "XAXX010101000"
moneda = "MXN"
ejercicio_fiscal = 2026
responsable = "Tesorero"
spreadsheet_maestro = ""

[costos_fijos]
# Gastos recurrentes con monto predecible
[[costos_fijos.item]]
nombre = "Renta oficina"
monto = 15000.00
frecuencia = "mensual"
categoria = "oficina"
dia_vencimiento = 5

[[costos_fijos.item]]
nombre = "Salarios base"
monto = 45000.00
frecuencia = "quincenal"
categoria = "nomina"
dia_vencimiento = 15

[[costos_fijos.item]]
nombre = "Servicios cloud"
monto = 2500.00
frecuencia = "mensual"
categoria = "tecnologia"
dia_vencimiento = 20

[costos_variables]
# Gastos que cambian segun volumen de operacion
[[costos_variables.item]]
nombre = "Materiales de produccion"
categoria = "materiales"
presupuesto_mensual = 30000.00

[[costos_variables.item]]
nombre = "Publicidad digital"
categoria = "marketing"
presupuesto_mensual = 12000.00
