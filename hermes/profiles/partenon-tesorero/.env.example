# Partenon Tesorero — Variables de entorno

# Google Workspace service account JSON (ruta al archivo o contenido base64)
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/google-service-account.json

# OpenRouter API key para el modelo default
OPENROUTER_API_KEY=sk-or-v1-...

# Moneda base del Tesorero (opcional, default: MXN)
PARTENON_TESORERO_MONEDA=MXN

# ID de spreadsheet maestra de finanzas (opcional, se crea si no existe)
PARTENON_TESORERO_SHEET_ID=

# Entorno: development | staging | production
PARTENON_ENV=development
