# Partenon Treasurer — Environment variables

# Google Workspace service account JSON (path to file or base64 content)
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/google-service-account.json

# OpenRouter API key for the default model
OPENROUTER_API_KEY=sk-or-v1-...

# Treasurer base currency (optional, default: MXN)
PARTENON_TESORERO_CURRENCY=MXN

# Master finance spreadsheet ID (optional, created if it does not exist)
PARTENON_TESORERO_SHEET_ID=

# Environment: development | staging | production
PARTENON_ENV=development
