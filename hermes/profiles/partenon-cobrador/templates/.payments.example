# Partenon Collector — Master payments file
# Copy this file as `.payments` in the client/company root directory.
# All amounts are stored as integers in the smallest currency unit (cents).

metadata:
  version: "0.1.0"
  profile: partenon-cobrador
  currency: MXN
  timezone: America/Mexico_City
  created: "2026-06-26"

products:
  - id: prod_example_001
    name: "Initial consultation"
    description: "60-minute diagnostic session."
    active: true

  - id: prod_example_002
    name: "Monthly retainer"
    description: "Monthly accompaniment hour package."
    active: true

prices:
  - id: price_example_001
    product_id: prod_example_001
    amount: 150000
    currency: mxn
    type: one_time

  - id: price_example_002
    product_id: prod_example_002
    amount: 50000
    currency: mxn
    type: recurring
    interval: month
    interval_count: 1

links:
  - id: link_example_001
    price_id: price_example_001
    url: "https://buy.stripe.com/test_example"
    client_email: client@example.com
    concept: "Initial consultation"
    created: "2026-06-26T10:00:00-06:00"
    expires: "2026-07-26T10:00:00-06:00"
    status: active

subscriptions:
  - id: sub_example_001
    client_email: client@example.com
    price_id: price_example_002
    stripe_subscription_id: sub_xxxxxxxxxxxxxxxx
    status: active
    cycle: month
    next_charge: "2026-07-26"
    failed_attempts: 0

clients:
  - id: cus_example_001
    email: client@example.com
    name: "Example Client"
    phone: "+52 55 1234 5678"
    payments_responsible: "John Doe"
    preferred_method: card
    history: punctual

payments:
  - id: pay_example_001
    stripe_payment_intent_id: pi_xxxxxxxxxxxxxxxx
    client_email: client@example.com
    price_id: price_example_001
    link_id: link_example_001
    amount: 150000
    currency: mxn
    stripe_fee: 4350
    status: paid
    created_at: "2026-06-26T10:00:00-06:00"
    paid_at: "2026-06-26T11:30:00-06:00"
    synced_with_treasurer: true

reminders:
  - id: rem_example_001
    client_email: client@example.com
    payment_id: pay_example_001
    type: before_due
    sent_at: "2026-06-23T09:00:00-06:00"
    channel: gmail
    status: sent

policies:
  max_reminders: 3
  days_before_reminder: 3
  days_after_due_for_escalation: 3
  allow_partial_payments: false
