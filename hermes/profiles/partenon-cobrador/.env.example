# Partenon Cobrador — Variables de entorno
# Copia este archivo como .env y completa los valores reales.

# Stripe MCP
STRIPE_SECRET_KEY=sk_test_REPLACE_ME_IN_ENV

# OpenRouter API para el modelo default del perfil
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME_IN_ENV

# Google Workspace MCP (opcional, requerido para enviar recordatorios formales)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# G-Brain MCP (memoria compartida)
GBRAIN_DATABASE_URL=postgresql://localhost:5432/gbrain
