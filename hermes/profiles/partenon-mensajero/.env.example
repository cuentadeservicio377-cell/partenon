# Partenon Mensajero — Variables de entorno requeridas
# Copiar a .env y completar los valores reales.

# OpenRouter: usado como provider de modelos por defecto
OPENROUTER_API_KEY=sk-or-v1-...

# Gmail MCP: token de acceso para envio y lectura de correos
GMAIL_ACCESS_TOKEN=ya29.a0ARrdaM...

# Google Workspace (opcional si se usa service account via MCP)
# GOOGLE_SERVICE_ACCOUNT_PATH=config/google-service-account.json

# G-Brain MCP
# GBRAIN_MCP_URL=http://localhost:3001

# WordPress / SSH (solo si se publica contenido en sitio propio)
# WP_BASE_URL=https://miempresa.com
# WP_USERNAME=admin
# WP_APPLICATION_PASSWORD=xxxx xxxx xxxx xxxx
# SSH_HOST=miempresa.com
# SSH_USER=deploy
