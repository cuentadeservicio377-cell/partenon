# Partenon Herald — Required environment variables
# Copy to .env and fill in real values.

# OpenRouter: used as the default model provider
OPENROUTER_API_KEY=sk-or-v1-...

# Gmail MCP: access token for sending and reading emails
GMAIL_ACCESS_TOKEN=ya29.a0ARrdaM...

# Google Workspace (optional if service account is used via MCP)
# GOOGLE_SERVICE_ACCOUNT_PATH=config/google-service-account.json

# G-Brain MCP
# GBRAIN_MCP_URL=http://localhost:3001

# WordPress / SSH (only if publishing content on your own site)
# WP_BASE_URL=https://mycompany.com
# WP_USERNAME=admin
# WP_APPLICATION_PASSWORD=xxxx xxxx xxxx xxxx
# SSH_HOST=mycompany.com
# SSH_USER=deploy
