{
  "id": "herald-weekly-content-plan",
  "name": "Herald — Weekly content plan",
  "description": "Plans the week's content for active channels defined in .design",
  "schedule": "0 9 * * 1",
  "timezone": "America/Mexico_City",
  "enabled": true,
  "profile": "partenon-herald",
  "skill": "comms",
  "steps": [
    {
      "order": 1,
      "action": "read",
      "target": ".design",
      "purpose": "Load brand voice, channels, and key messages"
    },
    {
      "order": 2,
      "action": "run",
      "tool": "skills/comms/tools/content_calendar.py",
      "args": [
        "{brand.positioning.what_you_sell}",
        "{brand.channels}",
        "7"
      ],
      "purpose": "Generate weekly calendar with brand angle"
    },
    {
      "order": 3,
      "action": "run",
      "tool": "skills/comms/tools/copy_generator.py",
      "args": [
        "post",
        "{brand.positioning.what_you_sell}",
        "{brand.channels.0}"
      ],
      "purpose": "Generate base copy for the main channel"
    },
    {
      "order": 4,
      "action": "notify",
      "channel": "gbrain",
      "message": "Weekly content plan generated for review",
      "purpose": "Register mission and wait for approval"
    }
  ],
  "output": {
    "folder": "output/campaigns",
    "file_pattern": "CAL-{date}-*/content-calendar.json"
  },
  "approval_required": true
}
