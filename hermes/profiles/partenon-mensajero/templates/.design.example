meta:
  version: "0.1.0"
  profile: partenon-mensajero
  updated_at: "2026-01-01T00:00:00"

brand:
  brand_name: "Company name"
  website: "https://mycompany.com"
  industry: "services"
  market: "Mexico / Latin America"
  stage: "growth"

positioning:
  what_you_sell: "Main service or product in one sentence"
  who_you_help: "Role, industry, and size of the ideal buyer"
  how_you_do_it: "Mechanism, process, or key differentiator"
  positioning_statement: "For [audience] who [pain], [brand] offers [offer] that [result]"
  differentiator: "Why they choose you before another option"

voice:
  tone: "direct and close"
  form_of_address: "you"
  style: "clear, no filler, no emojis"
  emojis: false
  slang: false

audience:
  primary:
    role: "Small business owner or operations manager"
    industry: "retail / services / manufacturing"
    size: "5-50 employees"
    pain: "They lose time on repetitive tasks and lack clarity on metrics"
    outcome: "Ordered operations and data-driven decisions"
    objections:
      - "It looks complex to implement"
      - "We don't have time to migrate"
  secondary:
    - role: "Growing freelancer"
      pain: "Does not have scalable processes"

channels:
  - linkedin
  - instagram
  - blog
  - newsletter

messaging:
  key_messages:
    - "We organize your SME operations without friction"
    - "Decisions with data, not intuition"
    - "Implementation in days, not months"
  prohibited_claims:
    - "100% automated"
    - "Guaranteed results"
    - "The best solution on the market"
  proof_points:
    - "+50 companies operating with the system"
    - "Average reduction of 10h per week in administrative tasks"
  cta_matrix:
    awareness: "See how it works"
    consideration: "Schedule a diagnostic call"
    decision: "Start this week"

content:
  pillars:
    - name: "Educational"
      purpose: "Teach something useful about operations and data"
    - name: "Social proof"
      purpose: "Show results and real cases"
    - name: "Behind the scenes"
      purpose: "Show how we work"
  topics_to_own:
    - "operations in SMEs"
    - "automation without friction"
    - "metrics that matter"
  topics_to_avoid:
    - "open criticism of competitors"
    - "promises of income without evidence"

operations:
  final_approver: "Owner or responsible person name"
  autonomy:
    draft_copy: true
    create_calendar: true
    publish_social: false
    send_email: false
    launch_ads: false
