# .ops — Perfil Estratega de Partenon
# Copia este archivo como .ops en la raiz del workspace y ajusta segun tu negocio.

profile: partenon-estratega
owner: "Nombre del dueno"
assistant_name: "Estratega"

calendar:
  morning_briefing: "08:00"
  midday_pulse: "14:00"
  evening_wrap: "18:00"
  weekly_planning: "lunes 09:00"
  weekly_retro: "domingo 20:00"
  timezone: "America/Mexico_City"

nudges:
  max_per_day: 3
  max_repeat: 3
  quiet_hours:
    start: "22:00"
    end: "07:00"

projects:
  default_duration_days: 30
  auto_checklist: true
  notify_diplomatico_on_milestones: true

tasks:
  default_priority: media
  default_duration_days: 7
  escalate_blocked_after_hours: 48

goals:
  review_day: domingo
  default_type: semanal
  departments:
    - general
    - ventas
    - operaciones
    - finanzas

# Ejemplos de proyecto
checklist_example:
  project: "Evento corporativo ACME"
  client: "ACME"
  type: eventos
  phases:
    pre-evento:
      - Confirmar fecha y lugar con cliente
      - Contratar proveedores
      - Preparar mobiliario y decoracion
      - Coordinar logistica
      - Briefing con equipo
    durante-evento:
      - Setup en lugar
      - Recepcion de invitados
      - Coordinacion en tiempo real
      - Resolucion de imprevistos
    post-evento:
      - Desmontaje y recoleccion
      - Facturacion final
      - Evaluacion con cliente

# Ejemplos de tareas
task_examples:
  - title: "Confirmar catering"
    project: "Evento corporativo ACME"
    responsible: "Estratega"
    due: "2026-07-01"
    priority: alta
  - title: "Llamar a proveedor de mobiliario"
    project: "Evento corporativo ACME"
    responsible: "Diplomatico"
    due: "2026-07-02"
    priority: media

# Ejemplos de metas
goal_examples:
  - title: "Cerrar 2 contratos"
    type: semanal
    department: ventas
    target: 2
    unit: contratos
    kpi_source: pipeline.contratado
  - title: "Completar 5 tareas pendientes"
    type: semanal
    department: operaciones
    target: 5
    unit: tareas
    kpi_source: tasks.completadas

# Ejemplos de calendario / recordatorios
calendar_examples:
  - title: "Kickoff ACME"
    date: "2026-06-30T10:00:00"
    attendees: ["cliente@acme.com"]
    reminder_minutes: 60
  - title: "Revision semanal"
    date: "2026-07-03T16:00:00"
    recurrence: weekly
