# Partenon — Global environment variables
# Copy this file to .env and fill in your real credentials.
# NEVER commit the .env file to GitHub.

# =============================================================================
# Environment
# =============================================================================
PARTENON_ENV=development

# =============================================================================
# Models / LLMs (OpenRouter is the default)
# =============================================================================
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME_IN_ENV

# Optional alternatives
OPENAI_API_KEY=sk-REPLACE_ME_IN_ENV
NVIDIA_API_KEY=nvapi-REPLACE_ME_IN_ENV
KIMI_API_KEY=REPLACE_ME_IN_ENV

# =============================================================================
# Google Workspace — Shared work surface
# =============================================================================
# Option A: Service account JSON file (recommended for server/automation)
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/google-service-account.json

# Option B: OAuth 2.0 desktop client (interactive authentication)
# GOOGLE_OAUTH_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=REPLACE_ME

# =============================================================================
# Stripe — Payments and collections
# =============================================================================
STRIPE_SECRET_KEY=sk_test_REPLACE_ME_IN_ENV
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME_IN_ENV
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME_IN_ENV

# =============================================================================
# Slack — Strategist notifications
# =============================================================================
SLACK_BOT_TOKEN=xoxb-REPLACE_ME_IN_ENV
SLACK_TEAM_ID=T_REPLACE_ME_IN_ENV

# =============================================================================
# G-Brain — Persistent memory via MCP
# =============================================================================
GBRAIN_DATABASE_URL=postgresql://localhost:5432/gbrain

# =============================================================================
# Partenon API (FastAPI)
# =============================================================================
# Secret used to sign JWT tokens for dashboard/API sessions. If not set, the
# API falls back to DASHBOARD_AUTH_SECRET so existing setups keep working.
PARTENON_API_SECRET=REPLACE_WITH_A_STRONG_SECRET_AT_LEAST_32_CHARS

# Host and port where the FastAPI server listens.
PARTENON_API_HOST=127.0.0.1
PARTENON_API_PORT=8000

# Origin of the Next.js dashboard, used for CORS.
DASHBOARD_ORIGIN=http://localhost:3000

# =============================================================================
# Local dashboard (Next.js)
# =============================================================================
# Strong secret used to sign session cookies. Must be at least 32 characters.
# The installer generates one automatically; otherwise set it before starting
# the dashboard. Also used as a fallback JWT secret by the API.
DASHBOARD_AUTH_SECRET=REPLACE_WITH_A_STRONG_SECRET_AT_LEAST_32_CHARS

# URL the dashboard uses to reach the FastAPI backend.
PARTENON_API_URL=http://127.0.0.1:8000

# Dashboard credentials. The installer generates these; otherwise set them
# explicitly. There are no fallback values.
# DASHBOARD_APP_USERNAME=admin
# DASHBOARD_APP_PASSWORD=partenon

# =============================================================================
# Hermes Agent CLI (optional)
# Hermes is distributed separately by Nous Research.
# Set this to the directory containing your local `hermes` binary,
# or leave it empty to use the binary available in PATH.
# =============================================================================
# HERMES_CLI_PATH=/path/to/hermes/bin
