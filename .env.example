# Partenon Environment Template
# Copy to .env and fill with your credentials.

# Google Workspace service account JSON (single-line or path to file)
GOOGLE_SERVICE_ACCOUNT_JSON=

# Google Drive folder where Partenon will store files
HERMES_FOLDER_ID=

# Stripe
STRIPE_SECRET_KEY=

# Gmail MCP
GMAIL_ACCESS_TOKEN=

# Model providers (at least one)
OPENROUTER_API_KEY=
OPENAI_API_KEY=
KIMI_API_KEY=
NVIDIA_API_KEY=

# G-Brain
GBrain_DATABASE_URL=postgresql://localhost:5432/gbrain

# Telegram bot (optional)
TELEGRAM_BOT_TOKEN=

# Dashboard auth (optional)
DASHBOARD_APP_USERNAME=admin
DASHBOARD_APP_PASSWORD=change-me
DASHBOARD_AUTH_SECRET=change-me
